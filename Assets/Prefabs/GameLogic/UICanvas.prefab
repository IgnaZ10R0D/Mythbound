--- !u!114 &934122727019215057
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2435789730034787860}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6cb90e80eb896e142b032fe22fb15643, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueLines:
  - text: Eeeeeh... this is odd... I'm pretty sure this wasn't on the map. Is this
      a shortcut or something?
    color: {r: 1, g: 0, b: 0, a: 1}
    alphaOverride: 1
  - text: Oh. What a surprise. A human crossing my bridge without permission. The
      gall of humans these days...
    color: {r: 0, g: 0, b: 1, a: 1}
    alphaOverride: 1
  - text: Oh! Uh... sorry? I guess? Wait. Since when do you own this bridge?
    color: {r: 1, g: 0, b: 0.17582655, a: 0}
    alphaOverride: 1
  - text: Since these candles started to glow... however everybody seems dedicated
      to crossing the bridge anyways. I hate them.
    color: {r: 0, g: 0, b: 1, a: 0}
    alphaOverride: 1
  - text: I just wanted to follow the path but... I think I got lost.
    color: {r: 1, g: 0, b: 0, a: 0}
    alphaOverride: 1
  - text: Everybody says that. You're probably no different. Came to mock me like
      those Miko?
    color: {r: 0, g: 0, b: 1, a: 1}
    alphaOverride: 1
  - text: Err... Lady, I have no idea what you're talking about. I'm just following
      orders.
    color: {r: 1, g: 0, b: 0, a: 1}
    alphaOverride: 1
  - text: Wait, they're not orders. Instructions? It was more like instinct...
    color: {r: 1, g: 0, b: 0, a: 1}
    alphaOverride: 1
  - text: Great, now I'm confused too.
    color: {r: 1, g: 0, b: 0, a: 1}
    alphaOverride: 1
  - text: So, not only a trespasser, but also an idiot... Oh goody... one of those
      days...
    color: {r: 0, g: 0, b: 1, a: 1}
    alphaOverride: 1
  - text: Well... Little human, if you want to cross. You better prove you're not
      just another errand boy for a pesky fox.
    color: {r: 0, g: 0, b: 1, a: 1}
    alphaOverride: 1
  - text: Wait a sec. How did you even figure out the fox part?
    color: {r: 1, g: 0, b: 0, a: 1}
    alphaOverride: 1
  - text: Human, the stench of her is all over you. And that makes me jealous...
      A LOT!
    color: {r: 0, g: 0, b: 1, a: 1}
    alphaOverride: 1
  - text: ...The risk I took was calculated. But man, am I bad at math.
    color: {r: 1, g: 0, b: 0, a: 1}
    alphaOverride: 1
